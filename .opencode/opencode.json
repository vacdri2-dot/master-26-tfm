{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "Azure": {
      "type": "local",
      "command": ["npx", "-y", "@azure/mcp@latest", "server", "start"]
    },
    "docs-langchain": {
      "type": "remote",
      "url": "https://docs.langchain.com/mcp"
    }
  }
}
